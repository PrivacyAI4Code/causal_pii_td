public class MinimumPathSum {
    public int minPathSum(int[][] grid) {
        int m = grid.length;
        int n = grid[0].length;
        int[][] dp = new int[m][n];
        for (int i = 0; i < m; i++) {
            for (int j = 0; j < n; j++) {
                int sum = 0;
                if (i > 0) {
                    sum += dp[i - 1][j];
                }
                if (j > 0) {
                    sum += dp[i][j - 1];
                }
                dp[i][j] = sum + grid[i][j];
            }
        }
        return dp[m - 1][n - 1];
    }

