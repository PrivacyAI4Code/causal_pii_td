import com.github.lukaspili.reactivebilling.service.BillingService;

import io.reactivex.Observable;
import io.reactivex.observers.DisposableObserver;

/**
 * Created by Lukas Pili on 2017-01-19.
 */

public class IsBillingSupportedObservable extends BaseObservable<Response> {

    public IsBillingSupportedObservable(Context context, PurchaseType purchaseType) {
        super(context, purchaseType);
    }

    @Override
    protected Observable<Response> createObservable(Context context, PurchaseType purchaseType) {
        return Observable.create(new DisposableObserver<Response>() {
            @Override
            public void onNext(Response response) {
                if (response.isSuccessful()) {
                    observer.onNext(response);
                    observer.onCompleted();
                } else {
                    observer.onError(new Throwable(response.getErrorMessage()));
                }
            }

            @Override
            public void onError(Throwable e) {
                observer.onError(e);
            }

            @Override
            public void onCompleted() {
                observer.onCompleted();
            }
        });
    }

    @Override
    protected Observable<Response> getObservable(Context context, PurchaseType purchaseType) {
        return BillingService.getInstance().isBillingSupported(context, purchaseType);
    }
}
