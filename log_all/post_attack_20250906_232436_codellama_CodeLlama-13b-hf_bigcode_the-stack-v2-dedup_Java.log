    }

    @Override
    public View onCreateView(LayoutInflater inflater, ViewGroup container,
                             Bundle savedInstanceState) {
        View view = inflater.inflate(R.layout.dialogo_nuevo, container, false);
        mEditText = (EditText) view.findViewById(R.id.ed_texto_dialogo);
        mEditText.setText("");
        mEditText.requestFocus();
        return view;
    }

    @Override
    public void onStart() {
        super.onStart();
        // When the dialog is displayed, get the EditText and select the text
        mEditText = (EditText) getDialog().findViewById(R.id.ed_texto_dialogo);
        mEditText.requestFocus();
        mEditText.selectAll();
    }

    @Override
    public void onDismiss(DialogInterface dialog) {
        super.onDismiss(dialog);
        // When the dialog is dismissed, clear the EditText
        mEditText.setText("");
    }
}
