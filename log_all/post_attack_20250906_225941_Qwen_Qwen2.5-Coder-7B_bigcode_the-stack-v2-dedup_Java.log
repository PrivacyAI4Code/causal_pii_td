    public boolean equals(Object obj) {
        if (this == obj) {
            return true;
        }
        if (obj == null) {
            return false;
        }
        if (getClass() != obj.getClass()) {
            return false;
        }
        UnloadedMarketDataEntry other = (UnloadedMarketDataEntry) obj;
        if (mSymbol == null) {
            if (other.mSymbol != null) {
                return false;
            }
        } else if (!mSymbol.equals(other.mSymbol)) {
            return false;
        }
        return true;
    }

    @Override
    public int compareTo(MarketDataEntry o) {
        return mSymbol.compareTo(o.getSymbol());
