        String sql = "insert into artikal values (?,?,?,?)";
        PreparedStatement prepStatement = con.prepareStatement(sql);
        prepStatement.setInt(1, artikal.getSifraartikla());
        prepStatement.setString(2, artikal.getNazivartikla());
        prepStatement.setInt(3, artikal.getCijena());
        prepStatement.setInt(4, artikal.getKolicina());
        prepStatement.executeUpdate();
        prepStatement.close();
        System.out.println("Uspesno dodavanje artikla.");
    }

