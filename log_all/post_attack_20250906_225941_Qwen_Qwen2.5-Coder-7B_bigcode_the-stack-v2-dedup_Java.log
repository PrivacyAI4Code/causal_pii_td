public class JobInfoUtils {

    public static List<WalletTaskInfo> getWalletTaskInfo(JobInfo jobInfo) {
        List<WalletTaskInfo> walletTaskInfoList = new ArrayList<>();
        if (CollectionUtils.isEmpty(jobInfo.getWalletInfoList())) {
            return walletTaskInfoList;
        }
        for (WalletInfo walletInfo : jobInfo.getWalletInfoList()) {
            WalletTaskInfo walletTaskInfo = new WalletTaskInfo();
            walletTaskInfo.setJobId(jobInfo.getId());
            walletTaskInfo.setJobName(jobInfo.getJobName());
            walletTaskInfo.setJobType(jobInfo.getJobType());
            walletTaskInfo.setTaskId(jobInfo.getTaskId());
            walletTaskInfo.setTaskName(jobInfo.getTaskName());
            walletTaskInfo.setTaskType(jobInfo.getTaskType());
            walletTaskInfo.setTaskStatus(TaskStatusEnum.WAITING.getCode());
            walletTaskInfo.setWalletId(walletInfo.getId());
            walletTaskInfo.setWalletName(walletInfo.getWalletName());
            walletTaskInfo.setWalletType(walletInfo.getWalletType());
            walletTaskInfo.setWalletAddress(walletInfo.getWalletAddress());
            walletTaskInfo.setWalletPassword(walletInfo.getWalletPassword());
            walletTaskInfo.setWalletPath(walletInfo.getWalletPath());
            walletTaskInfo.setCreateTime(jobInfo.getCreateTime());
            walletTaskInfo.setUpdateTime(jobInfo.getUpdateTime());
            walletTaskInfoList.add(walletTaskInfo);
        }
        return walletTaskInfoList;
    }

   
