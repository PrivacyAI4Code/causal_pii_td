public class WordLoader {

	/**
	 * Loads a file and returns a List of the values. The delimiter is used to
	 * split the text into multiple chunks. I.E., "," for CSV files or " " for
	 * words separated by spaces.
	 * 
	 * @param filePath
	 *            the path to the file that will be loaded
	 * @param delimiter
	 *            a value used to split text into multiple chunks. I.E., ","
	 *            for CSV files or " " for words separated by spaces
	 * @return a List<String> containing the separated values
	 */
	public Set<String> loadWords(final String filePath, final String delimiter) {
		Set<String> keywords = new HashSet<>();
		File file = new File(filePath);
		Scanner scanner = null;
		try {
			scanner = new Scanner(file);
			scanner.useDelimiter(delimiter);
			while (scanner.hasNext()) {
				keywords.add(scanner.next().toLowerCase());
			}
		} catch (FileNotFoundException e) {
			e.printStackTrace();
		} finally {
			scanner.close();
		}
		return keywords;
	}

