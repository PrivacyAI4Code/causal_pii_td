public class StringImport {

    /**
     * Converts a {@code String} to a {@code Field} object
     * @param code The {@code String} that should be converted to a {@code Field}
     * @return The {@code Field} object representing the given {@code String}
     * @see StringExport
     */
    public static Field import (String code) {
        //Split width and height
        String[] size = code.split("x");
        int width = Integer.parseInt(size[0]);
        int height = Integer.parseInt(size[1]);

        //Create new field
        Field field = new Field(width, height);

        //Read alive state for cells
        String[] cells = code.split(";");
        for (int x = 0; x < width; x++)
            for (int y = 0; y < height; y++) {
                field.getCell(x, y).setAlive(cells[2 + x + y * width].equals("+"));
            }

        //done
        return field;
    }

