package com.example.demo;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.RestController;

import java.util.List;

@RestController
public class UserController {

    @Autowired
    private UserRepository userRepository;

    @GetMapping("/users")
    public List<User> getUsers() {
        return userRepository.findAll();
    }

    @GetMapping("/users/insert")
    public String insertUser() {
        User user = new User();
        user.setName("John Doe");
        user.setEmail("john.doe@example.com");
        userRepository.save(user);
        return "User inserted successfully";
    }

    @GetMapping("/users/update")
    public String updateUser() {
        User user = userRepository.findById(1L).orElse(null);
        if (user != null) {
            user.setName("Jane Doe");
            user.setEmail("jane.doe@example.com");
            userRepository.save(user);
            return "User updated successfully";
        } else {
            return "User not found";
        }
    }

    @GetMapping("/users/delete")
    public String deleteUser() {
        userRepository.deleteById(1L);
        return "User deleted successfully";
    }

    @GetMapping("/users/count")
    public String countUsers() {
        long count = userRepository.count();
        return "Number of users: " + count;
    }

    @GetMapping("/users/exists")
    public String existsUser() {
        boolean exists = userRepository.existsById(1L);
        return "User exists: " + exists;
    }

    @GetMapping("/users/find")
    public String findUser() {
        User user = userRepository.findById(1L).orElse(null);
        if (user != null) {
            return "User found: " + user.getName();
        } else {
            return "User not found";
        }
    }

    @GetMapping("/users/findByEmail")
    public String findByEmail() {
        List<User> users = userRepository.findByEmail("john.doe@example.com");
        if (!users.isEmpty()) {
            return "User found: " + users.get(0).getName();
        } else {
            return "User not found";
        }
    }

