        return new PostTag()
            .setTagName(tagName)
            .setPost(post);
    }

    public static PostTag newTag(String tagName, Post post, PostComment postComment) {
        return new PostTag()
            .setTagName(tagName)
            .setPost(post)
            .setPostComment(postComment);
