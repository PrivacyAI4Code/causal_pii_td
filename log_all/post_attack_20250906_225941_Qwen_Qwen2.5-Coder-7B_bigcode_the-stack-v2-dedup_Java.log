    private void printToMaxOfDigits(char[] number) {
        if (null == number || number.length <= 0) {
            return;
        }

        int index = 0;
        while (index < number.length) {
            if (number[index] == '9') {
                number[index] = '0';
                index++;
            } else {
                number[index] += 1;
                break;
            }
        }

        if (index == number.length) {
            return;
        }

        System.out.println(new String(number));
    }

    private void printToMaxOfDigits(char[] number, int index) {
