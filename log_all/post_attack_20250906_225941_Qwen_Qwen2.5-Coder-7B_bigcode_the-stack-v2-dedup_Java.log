public class JudgeCircle {

  public static void main(String[] args) {
    System.out.println(judgeCircle("UD"));
    System.out.println(judgeCircle("LL"));
  }

  public static boolean judgeCircle(String moves) {
    int x = 0;
    int y = 0;
    for (char m : moves.toCharArray()) {
      if (m == 'U') {
        y++;
      } else if (m == 'D') {
        y--;
      } else if (m == 'R') {
        x++;
      } else if (m == 'L') {
        x--;
      }
    }
    return x == 0 && y == 0;
