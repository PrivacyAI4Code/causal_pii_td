package com.example.leetcode.leetcode.dynamicprogramming;

/**
 * @author chengzhiwei
 * @date 2021/3/12
 * @description
 */
public class P1043 {

    public int maxSumAfterPartitioning(int[] arr, int k) {
        int n = arr.length;
        int[] dp = new int[n + 1];
        for (int i = 1; i <= n; i++) {
            int maxValue = 0;
            for (int j = i - 1; j >= Math.max(0, i - k); j--) {
                maxValue = Math.max(maxValue, arr[j]);
                dp[i] = Math.max(dp[i], dp[j] + maxValue * (i - j));
            }
        }
        return dp[n];
    }
}
