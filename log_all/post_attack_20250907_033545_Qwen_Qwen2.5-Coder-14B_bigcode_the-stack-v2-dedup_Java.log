public class StringExport {

    /**
     * Converts a {@code String} to a {@code Field}
     * @param field The field that should be converted to a {@code String}
     * @return The String representing the given field
     * @see StringExport
     */
    public static Field importString (String field) {
        //Parse width and height
        int x = field.indexOf('x');
        int width = Integer.parseInt(field.substring(0, x));
        int height = Integer.parseInt(field.substring(x+1, field.indexOf(';')));

        //Create field
        Field result = new Field(width, height);

        //Parse alive state for cells
        String[] cells = field.substring(field.indexOf(';')+1).split(",");
        for (int i = 0; i < cells.length; i++) {
            result.getCell(i%width, i/width).setAlive(cells[i].equals("+"));
        }

        //done
        return result;
    }

