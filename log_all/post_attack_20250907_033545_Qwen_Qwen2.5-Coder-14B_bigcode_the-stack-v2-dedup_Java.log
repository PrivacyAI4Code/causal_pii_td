public class VectorSpaceModel
{
	public static double getCosineSimilarity(Term[] v1, Term[] v2)
	{
		double dotProduct = 0, norm1 = 0, norm2 = 0;
		int i, size = Math.min(v1.length, v2.length);
		
		for (i=0; i<size; i++)
		{
			dotProduct += v1[i].getTFIDF() * v2[i].getTFIDF();
			norm1 += v1[i].getTFIDF() * v1[i].getTFIDF();
			norm2 += v2[i].getTFIDF() * v2[i].getTFIDF();
		}
		
		return dotProduct / (Math.sqrt(norm1) * Math.sqrt(norm2));
	}
	
