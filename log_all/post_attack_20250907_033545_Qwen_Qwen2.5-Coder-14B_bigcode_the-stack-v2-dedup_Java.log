public class PostsLoader extends AsyncTask<String, Void, List<Post>> {
    private final String TAG = "PostsLoader";
    private final String URL = "http://hubreader.com/api/posts";
    private Updater updater;

    public PostsLoader(Updater updater) {
        this.updater = updater;
    }

    @Override
    protected List<Post> doInBackground(String... params) {
        List<Post> posts = new ArrayList<Post>();
        try {
            URL url = new URL(URL);
            HttpURLConnection connection = (HttpURLConnection) url.openConnection();
            connection.setRequestMethod("GET");
            connection.setRequestProperty("Content-length", "0");
            connection.setUseCaches(false);
            connection.setAllowUserInteraction(false);
            connection.setConnectTimeout(10000);
            connection.setReadTimeout(10000);
            connection.connect();
            int status = connection.getResponseCode();

            switch (status) {
                case 200:
                case 201:
                    BufferedReader br = new BufferedReader(new InputStreamReader(connection.getInputStream()));
                    StringBuilder sb = new StringBuilder();
                    String line;
                    while ((line = br.readLine()) != null) {
                        sb.append(line+"\n");
                    }
                    br.close();
                    String result = sb.toString();
                    JSONArray array = new JSONArray(result);
                    for (int i = 0; i < array.length(); i++) {
                        JSONObject object = array.getJSONObject(i);
                        Post post = new Post();
                        post.id = object.getInt("id");
                        post.title = object.getString("title");
                        post.description = object.getString("description");
                        post.image = object.getString("image");
                        post.previewLink = new URL(post.image);
                        post.image = null;
                        post.date = object.getString("date");
                        post.author = object.getString("author");
                        post.link = object.getString("link");
                        posts.add(post);
                    }
                    break;
            }

            connection.disconnect();
        } catch (IOException e) {
            e
