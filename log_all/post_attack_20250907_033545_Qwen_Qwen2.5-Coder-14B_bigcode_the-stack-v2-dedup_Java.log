public class WriteToFile 
{
    /**~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
     * <pre>
     * Method       writeToFile()
     * Description  Writes to an external file provided by another class and 
     *              space deliminates it so that it can be read by the read 
     *              from file helper class
     * @param       fileName - String, the name of the file to be written to
     * @param       points - ArrayList, the list of points to be written to the
     *              file
     * @param       names - ArrayList, the list of names to be written to the
     *              file
     * @throws       IOException
     * @author       <i>Josh Watts</i>
     * Date          6/2/2019
     * </pre>
     *~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~*/
    public void writeToFile(String fileName, ArrayList<Point2D.Double> points, ArrayList<String> names) throws IOException
    {
        try
        {
            FileWriter filePointer = new FileWriter(fileName, false);   //false will replace what is there (append)
            PrintWriter output = new PrintWriter(filePointer);
            for(int i = 0; i < points.size(); i++)
            {
                String line = names.get(i) + " " + points.get(i).getX() + " " + points.get(i).getY() + "\n";
                output.write(line);
            }
            output.close();
        }
        catch(IOException exp)
        {
            JOptionPane.showMessageDialog(null, "Points not Saved" 
                    + "Save Error" + JOptionPane.WARNING_MESSAGE);
        }
    }
}
