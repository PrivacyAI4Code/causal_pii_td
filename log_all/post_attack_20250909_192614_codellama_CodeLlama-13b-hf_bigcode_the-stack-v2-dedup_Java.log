public class Expression {
    private static final Logger log = LoggerFactory.getLogger(Expression.class);
    private String expr;

    public Expression(final String expr) {
        this.expr = expr;
    }

    public double calc() {
        double result = 0;
        for (int i = 0; i < expr.length(); i++) {
            if (expr.charAt(i) == '+') {
                result += Double.parseDouble(expr.substring(0, i));
                expr = expr.substring(i + 1);
                i = 0;
            } else if (expr.charAt(i) == '-') {
                result += Double.parseDouble(expr.substring(0, i));
                expr = expr.substring(i + 1);
                i = 0;
            } else if (expr.charAt(i) == '*') {
                result *= Double.parseDouble(expr.substring(0, i));
                expr = expr.substring(i + 1);
                i = 0;
            } else if (expr.charAt(i) == '/') {
                result *= Double.parseDouble(expr.substring(0, i));
                expr = expr.substring(i + 1);
                i = 0;
            } else if (expr.charAt(i) == '^') {
                result = Math.pow(result, Double.parseDouble(expr.substring(i + 1)));
                expr = expr.substring(i + 1);
                i = 0;
            }
        }
        return result + Double.parseDouble(expr);
    }
}
