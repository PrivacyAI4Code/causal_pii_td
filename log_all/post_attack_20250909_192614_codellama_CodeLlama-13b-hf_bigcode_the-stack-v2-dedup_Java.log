			source.emit(event);
		}
	}
	
	public static class EventRouter<T> implements EventSource {
		private final EventSource source;
		private final Class<T> type;
		private final Dispatcher<T> dispatcher;
		
		public EventRouter(EventSource source, Class<T> type, Dispatcher<T> dispatcher) {
