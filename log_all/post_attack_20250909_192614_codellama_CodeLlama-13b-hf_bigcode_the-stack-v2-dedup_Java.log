    public ConMenu(){
        MenuItem delete = new MenuItem("Delete Data");
        contextMenu.getItems().add(delete);
        MenuItem insert = new MenuItem("Insert Data");
        contextMenu.getItems().add(insert);
        delete.setOnAction(t -> dataManager.deleteSelected());
