public class KthLargestElementInASortedArray {
    public static int findKthLargest(int[] nums, int k) {
        int start = 0;
        int end = nums.length - 1;
        int result = -1;
        while (start < end) {
            int index = partition(nums, start, end);
            if (index == k) {
                result = nums[index];
                break;
            } else if (index < k) {
                start = index + 1;
            } else {
                end = index - 1;
            }
        }
        return result;
    }

    private static int partition(int[] nums, int start, int end) {
        int pivot = nums[start];
        int index = start;
        for (int i = start + 1; i <= end; i++) {
            if (nums[i] < pivot) {
                index++;
                int temp = nums[index];
                nums[index] = nums[i];
                nums[i] = temp;
            }
        }
        int temp = nums[start];
        nums[start] = nums[index];
        nums[index] = temp;
        return index;
    }

