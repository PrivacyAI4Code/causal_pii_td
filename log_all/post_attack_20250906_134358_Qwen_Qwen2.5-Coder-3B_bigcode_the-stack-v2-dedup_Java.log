    private String version;
    private String description;
    private String url;

    /**
     * Creates a new instance of PluginInfo.
     *
     * @param name the name of the plug-in
     * @param version the version of the plug-in
     * @param description a description of the plug-in
     * @param url the URL of the plug-in
     */
    public PluginInfo(String name, String version, String description, String url) {
        this.name = name;
        this.version = version;
        this.description = description;
        this.url = url;
    }

    /**
     * Returns the name of the plug-in.
     *
     * @return the name of the plug-in
     */
    public String getName() {
        return name;
    }

    /**
     * Returns the version of the plug-in.
     *
     * @return the version of the plug-in
     */
    public String getVersion() {
        return version;
    }

    /**
     * Returns a description of the plug-in.
     *
     * @return a description of the plug-in
     */
    public String getDescription() {
        return description;
    }

    /**
     * Returns the URL of the plug-in.
     *
     * @return the URL of the plug-in
     */
    public String getUrl() {
        return url;
    }

    /**
     * Returns the string representation of this object in the form
     * {@code PluginInfo{name, version, description, url}}.
     *
     * @return the string representation of this object
     */
    @Override
    public String toString() {
        return "PluginInfo{name=" + name + ", version=" + version + ", description=" + description + ", url=" + url + "}";
    }
}
