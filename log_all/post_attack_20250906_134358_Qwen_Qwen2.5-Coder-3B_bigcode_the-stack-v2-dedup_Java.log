import java.util.ArrayList;
import java.util.List;

/**
 * @author raphael
 * @date 2021-01-19 10:13:40
 */
class FindAllAnagramsInAString {
    /**
     * Solution
     */
    private final int[] base = new int[26];

    private final int[] window = new int[26];

    private final List<Integer> result = new ArrayList<>();

    public List<Integer> findAnagrams(String s, String p) {
        // code
        int n = s.length();
        int m = p.length();
        if (n < m) {
            return result;
        }
        for (int i = 0; i < m; ++i) {
            ++window[p.charAt(i) - 'a'];
            ++base[s.charAt(i) - 'a'];
        }
        if (isAnagram()) {
            result.add(0);
        }
        for (int i = 1; i <= n - m; ++i) {
            --window[s.charAt(i - 1) - 'a'];
            ++window[s.charAt(i + m - 1) - 'a'];
            if (isAnagram()) {
                result.add(i);
            }
        }
        return result;
    }

    private boolean isAnagram() {
        for (int i = 0; i < 26; ++i) {
            if (window[i] != base[i]) {
                return false;
            }
        }
        return true;
    }
}
