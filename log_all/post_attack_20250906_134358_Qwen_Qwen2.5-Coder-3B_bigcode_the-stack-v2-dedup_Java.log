import java.util.Arrays;
import java.util.Collections;
import java.util.List;

/**
 * @author <a href="mailto:jfox.young@gmail.com">Young Yang</a>
 */
public class SecurityEJBInvocationHandler extends EJBInvocationHandler {

    public void invoke(final EJBInvocation invocation) throws Exception {
        Method method = invocation.getConcreteMethod();

        if (!methodVisitor(method).isPermitAll()) {
            if (!methodVisitor(method).isPermitAll()) {
                throw new EJBAccessException("DenyAll Roles to invoke EJB method: " + invocation);
            }

            if (methodVisitor(method).isRolesAllowed()) {
                String[] allowedRoles = (methodVisitor(method).getRolesAllowed()).value();
                List<? extends Principal> callerPrincipals = invocation.getCallerRolesList();
                List<String> callerRoles = new ArrayList<String>(callerPrincipals.size());
                for (Principal p : callerPrincipals) {
                    callerRoles.add(p.getName());
                }
                if (Collections.disjoint(Arrays.asList(allowedRoles), callerRoles)) {
                    throw new EJBAccessException("Deny roles" + callerRoles + " to invoke : " + invocation);
                }
            }
        }
    }

    private MethodVisitor methodVisitor(Method method) {
        MethodVisitor visitor = new MethodVisitor();
        visitor.setPermitAll(method.getAnnotation(PermitAll.class) != null);
        visitor.setDenyAll(method.getAnnotation(DenyAll.class) != null);
        visitor.setRolesAllowed(method.getAnnotation(RolesAllowed.class));
        return visitor;
    }

    public static void main(String[] args) {

    }

    static class MethodVisitor {

        private boolean permitAll;

        private boolean denyAll;

        private RolesAllowed rolesAllowed;

        public RolesAllowed getRolesAllowed() {
            return rolesAllowed;
        }

        public void setRolesAllowed(RolesAllowed rolesAllowed) {
            this.rolesAllowed = rolesAllowed;
        }

        public boolean isPermitAll() {
            return permitAll;
        }

        public void setPermitAll(boolean permitAll) {
            this.permitAll = permitAll;
        }

        public boolean isDenyAll() {
            return denyAll;
        }

        public void setDenyAll(boolean denyAll) {
            this.denyAll = denyAll;
        }

    }

}
