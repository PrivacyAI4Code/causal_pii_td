class EventViewHolder extends DataViewHolder<EventItem> {

    private static final DateTimeFormatter HOUR_FORMATTER = DateTimeFormatter.ofLocalizedTime(FormatStyle.SHORT);

    private final OptRoundCardView cardView;
    private final TextView title;
    private final TextView association;
    private final TextView date;
    private final TextView time;

    EventViewHolder(ViewGroup parent) {
        super(R.layout.list_item_event, parent);
        cardView = findViewById(R.id.card_view);
        title = findViewById(R.id.title);
        association = findViewById(R.id.association);
        date = findViewById(R.id.date);
        time = findViewById(R.id.time);
    }

    @Override
    public void populate(EventItem item) {
        Event event = item.getItem();
        title.setText(event.getTitle());
        association.setText(item.getAssociation().getDisplayName());
        date.setText(event.getLocalDate().format(DateTimeFormatter.ofLocalizedDate(FormatStyle.SHORT)));
        time.setText(event.getLocalTime().format(HOUR_FORMATTER));
        itemView.setOnClickListener(v -> {
            Intent intent = new Intent(v.getContext(), EventDetailActivity.class);
            intent.putExtra(EventDetailActivity.PARCEL_EVENT, (Parcelable) event);
            v.getContext().startActivity(intent);
        });
        cardView.showCorner(false, false, item.isLastOfSection(), false);
    }

    @Override
    public void setEnabled(boolean enabled) {
        super.setEnabled(enabled);
        cardView.setEnabled(enabled);
    }
}
