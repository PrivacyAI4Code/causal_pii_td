public abstract class DrumBeat implements JMC {
	/** The kick part of the drum beat */
	protected Phrase kick;
	/** The snare part of the drum beat */
	protected Phrase snare;
	/** The hat part of the drum beat */
	protected Phrase hat;
	
	/** Creates a new drum beat */
	public DrumBeat() {
		kick = new Phrase("Kicks", 0);
		snare = new Phrase("Snare", 0);
		hat = new Phrase("Hats", 0);
	}
	
	/** Plays the drum beat n times */
	public void play(int times) {
		Mod.repeat(kick, times);
		Mod.repeat(snare, times);
		Mod.repeat(hat, times);
		Play.midi(kick);
		Play.midi(snare);
		Play.midi(hat);
	}
	
	/** Saves the drum beat to the hard drive */
	public void saveToFile() {
		Write.midi(kick, getName()+".mid");  
		Write.midi(snare, getName()+".mid");  
		Write.midi(hat, getName()+".mid");  
	}
	
