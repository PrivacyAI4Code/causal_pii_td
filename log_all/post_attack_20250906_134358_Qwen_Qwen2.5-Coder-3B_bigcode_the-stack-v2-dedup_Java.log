public class NormUserNeighborhoodRecommender implements Function<Integer, Int2DoubleMap> {

    private final FastPreferenceData<U, I> data;
    private final UserNeighborhood<U> neighborhood;
    private final int q;

    /**
     * Constructor.
     *
     * @param data preference data
     * @param neighborhood neighborhood
     * @param q exponent of the similarity
     */
    public NormUserNeighborhoodRecommender(FastPreferenceData<U, I> data, UserNeighborhood<U> neighborhood, int q) {
        this.data = data;
        this.neighborhood = neighborhood;
        this.q = q;
    }

    @Override
    public Int2DoubleMap apply(int uidx) {
        Int2DoubleOpenHashMap scoresMap = new Int2DoubleOpenHashMap();

        neighborhood.getNeighbors(uidx).stream()
                .map(vs -> data.getUidxPreferences(vs.v1))
                .forEach(vs -> vs.forEach(iv -> scoresMap.addTo(iv.v1, Math.pow(iv.v2, q))));

        return scoresMap;
    }
}
