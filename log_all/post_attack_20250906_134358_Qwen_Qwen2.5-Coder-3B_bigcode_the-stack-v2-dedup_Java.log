import java.util.Set;

/**
 * @author Marko A. Rodriguez (http://markorodriguez.com)
 */
public final class HasLabelStep<V> extends FilterStep<V> implements Reversible {

    public HasLabelStep(final Traversal.Admin traversal, final String label) {
        super(traversal, label);
    }

    @Override
    protected boolean filter(final Vertex vertex) {
        return vertex.label().equals(this.label);
    }

    @Override
    public String toString() {
        return this.getStartStep().getClass().getSimpleName() + "[label=" + this.label + "]";
    }

    @Override
    public Set<TraverserRequirement> getRequirements() {
        return Collections.singleton(TraverserRequirement.OBJECT);
    }

    @Override
    public HasLabelStep<V> reverse() {
        return new HasLabelStep<>(getTraversal(), this.label);
    }

    @Override
    public HasLabelStep<V> clone() throws CloneNotSupportedException {
        final HasLabelStep<V> clone = (HasLabelStep<V>) super.clone();
        clone.label = this.label;
        return clone;
    }

    @Override
    public boolean equals(final Object object) {
        return super.equals(object) && object instanceof HasLabelStep && ((HasLabelStep) object).label.equals(this.label);
    }

    @Override
    public int hashCode() {
        return super.hashCode() ^ this.label.hashCode();
    }
}
