import org.springframework.beans.factory.annotation.Autowired;

/**
 * @author nichollsmc
 */
public class PortionAnalyteValidator implements BeanPropertyValidator {

  @Autowired
  private PortionAnalyteQueries portionAnalyteQueries;

  @Override
  public boolean validate(String portionAnalyteCode) {
    for (PortionAnalyte portionAnalyte : portionAnalyteQueries.getAllPortionAnalytes()) {
      if (portionAnalyteCode.equalsIgnoreCase(portionAnalyte.getPortionAnalyteCode())) {
        return true;
      }
    }

    return false;
  }

  public void setPortionAnalyteQueries(PortionAnalyteQueries portionAnalyteQueries) {
    this.portionAnalyteQueries = portionAnalyteQueries;
  }

  @Override
  public String getMessagePropertyKey() {
    return "gov.nih.nci.ncicb.tcga.dcc.common.bean.validation.PortionAnalyteValidator.message";
  }

}
