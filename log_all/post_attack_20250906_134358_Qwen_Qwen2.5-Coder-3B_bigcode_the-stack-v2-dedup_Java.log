        this.contacts = new HashSet<>();
    }

    public Trainer(String name, LocalDate birthday) {
        this();
        this.name = name;
        this.birthday = birthday;
    }

    public Trainer(String name, LocalDate birthday, Set<Pokemon> pokemon, Set<Trainer> contacts) {
        this();
        this.name = name;
        this.birthday = birthday;
        this.pokemon = pokemon;
        this.contacts = contacts;
    }

